.DS_Store
*.swp
*.*~
.idea/
.vscode/

# Backup files (e.g., data/cpp.json.bak from in-place edits)
*.bak

# Local diagnostic state from auto-publish gate trips (lang_repo_post_commit.sh)
.pe-exception.json

# Lockfile for serializing concurrent lang-repo post-commit hooks (flock target)
.pe-bench-hook.lock

# Compiled Go binary (rebuilt on demand from check_timing_delta.go)
scripts/check_timing_delta

# Dud audit: binary + baseline are local-only. Baseline contains comment-vs-bench
# detail that would leak answers for problems >100 if published. Hook regenerates
# baseline on first run if missing.
scripts/dud_audit
scripts/dud_audit_baseline.json

# SQLite SSOT for bench data — single file containing the runs (latest per
# lang+problem) + run_history (append-only) tables WITH answer column. NEVER
# committed; public repo carries only RESULTS.md + charts. The sanitization
# invariant is enforced at the file-system boundary (gitignore + sanitization_gate.py)
# rather than via field-level stripping.
# WAL mode creates two sidecar files which also stay gitignored.
data/bench-private.db
data/bench-private.db-wal
data/bench-private.db-shm

# Legacy: pre-2026-05-25 per-lang full-data JSON exports lived here. Directory
# removed in the SQLite migration; entry kept for defense-in-depth in case
# a future tool tries to write a path under this name.
data/private/

# Compiled Go binary for sanitization_gate's sibling dud_audit (also gitignored above)

# Python bytecode cache (auto-generated; ignored everywhere)
__pycache__/
*.pyc
