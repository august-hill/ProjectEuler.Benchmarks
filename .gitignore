.DS_Store
*.swp
*.*~
.idea/
.vscode/

# Backup files (e.g., data/cpp.json.bak from in-place edits)
*.bak

# Local diagnostic state from auto-publish gate trips (lang_repo_post_commit.sh)
.pe-exception.json

# Lockfile for serializing concurrent lang-repo post-commit hooks (flock target)
.pe-bench-hook.lock

# Compiled Go binary (rebuilt on demand from check_timing_delta.go)
scripts/check_timing_delta

# Dud audit: binary + baseline are local-only. Baseline contains comment-vs-bench
# detail that would leak answers for problems >100 if published. Hook regenerates
# baseline on first run if missing.
scripts/dud_audit
scripts/dud_audit_baseline.json

# Per-iter bench private data: full output WITH answer values for every problem
# (including >100). Used locally for verification + debugging. NEVER committed —
# the public data/*.json files are sanitized at write time by euler-bench
# per-iter --write, which strips the answer field for any problem >100.
data/private/

# Python bytecode cache (auto-generated; ignored everywhere)
__pycache__/
*.pyc
